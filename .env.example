# ClearingHouse.OS — Environment Variables
# Copy this file to .env and fill in your values

# Backend server port
PORT=3001

# Deployer private key (Base Sepolia / Sepolia)
# NEVER commit your real .env file — this is a template only
PRIVATE_KEY=

# RPC URLs
BASE_SEPOLIA_RPC=https://sepolia.base.org
SEPOLIA_RPC=https://ethereum-sepolia.publicnode.com

# Deployed contract address (Sepolia)
DEPLOYED_ADDRESS=0xD2E467F461cd8ffb57ba86fd37c3Dd99aF6D80B6

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=
